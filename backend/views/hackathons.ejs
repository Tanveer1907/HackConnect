<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hackathons - HackConnect</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="antialiased font-sans text-slate-800 overflow-x-hidden transition-colors duration-300 dark:bg-[#0f172a] dark:text-slate-200">
    <div class="flex flex-col flex-1 min-h-screen">
        <div class="flex flex-1 overflow-hidden max-w-[1600px] w-full mx-auto relative">
            <%- include('partials/sidebar') %>

            <main class="flex-1 p-6 md:p-10 overflow-y-auto z-10 bg-slate-50 dark:bg-transparent">
                <div class="flex justify-between items-end mb-10 mt-4">
                    <h2 class="text-3xl font-extrabold text-slate-900 drop-shadow-sm dark:text-white">Hackathon Management</h2>
                    <button class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-[0_4px_15px_rgba(59,130,246,0.4)] hover:shadow-[0_0_20px_rgba(59,130,246,0.6)] hover:-translate-y-0.5">
                        Create Hackathon
                    </button>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
                    <% if (hackathons && hackathons.length > 0) { %>
                        <% hackathons.forEach(hackathon => { %>
                            <div class="bg-white rounded-3xl shadow-sm border border-gray-200 overflow-hidden group hover:shadow-md hover:border-blue-300 transition-all duration-300 dark:bg-white/5 dark:backdrop-blur-md dark:border-white/10 dark:hover:border-blue-500/30 dark:hover:shadow-[0_0_30px_rgba(59,130,246,0.15)] flex flex-col">
                                <div class="h-48 bg-gradient-to-tr from-blue-600 to-purple-600 relative overflow-hidden shrink-0">
                                    <div class="absolute inset-0 bg-black/20 mix-blend-overlay group-hover:scale-110 transition-transform duration-700"></div>
                                    <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-md px-3 py-1 rounded-full text-white text-xs font-bold border border-white/30 shadow-sm">
                                        <%= hackathon.status || 'Active' %>
                                    </div>
                                </div>
                                <div class="p-6 flex-1 flex flex-col">
                                    <h3 class="text-xl font-extrabold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors dark:text-white dark:group-hover:text-blue-400"><%= hackathon.title %></h3>
                                    <p class="text-sm text-slate-600 mb-6 line-clamp-2 leading-relaxed dark:text-slate-400"><%= hackathon.description %></p>
                                    
                                    <div class="mt-auto pt-4 border-t border-gray-100 flex justify-between items-center dark:border-white/10">
                                        <span class="text-sm font-bold text-slate-900 bg-slate-100 px-3 py-1 rounded-lg dark:bg-slate-800 dark:text-white"><%= new Date(hackathon.date).toLocaleDateString() %></span>
                                        <div class="space-x-2">
                                            <button class="text-slate-400 hover:text-blue-600 transition-colors dark:hover:text-blue-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-span-full p-8 text-center text-slate-500 dark:text-slate-400 bg-white rounded-3xl border border-gray-200 dark:bg-white/5 dark:border-white/10">
                            No hackathons found in database.
                        </div>
                    <% } %>
                </div>
            </main>
        </div>
    </div>
</body>
</html>
