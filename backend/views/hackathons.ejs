<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hackathons - HackConnect</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="antialiased font-sans text-slate-800 overflow-x-hidden transition-colors duration-300 dark:bg-[#0f172a] dark:text-slate-200">
    <div class="flex flex-col flex-1 min-h-screen">
        <div class="flex flex-1 overflow-hidden max-w-[1600px] w-full mx-auto relative">
            <%- include('partials/sidebar') %>

            <main class="flex-1 p-6 md:p-10 overflow-y-auto z-10 bg-slate-50 dark:bg-transparent">
                <div class="flex justify-between items-end mb-10 mt-4">
                    <h2 class="text-3xl font-extrabold text-slate-900 drop-shadow-sm dark:text-white">Hackathon Management</h2>
                    <button onclick="document.getElementById('createModal').classList.remove('hidden')" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-xl font-bold transition-all shadow-[0_4px_15px_rgba(59,130,246,0.4)] hover:shadow-[0_0_20px_rgba(59,130,246,0.6)] hover:-translate-y-0.5">
                        Create Hackathon
                    </button>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
                    <% if (hackathons && hackathons.length > 0) { %>
                        <% hackathons.forEach(hackathon => { %>
                            <div class="bg-white rounded-3xl shadow-sm border border-gray-200 overflow-hidden group hover:shadow-md hover:border-blue-300 transition-all duration-300 dark:bg-white/5 dark:backdrop-blur-md dark:border-white/10 dark:hover:border-blue-500/30 dark:hover:shadow-[0_0_30px_rgba(59,130,246,0.15)] flex flex-col">
                                <div class="h-48 bg-slate-200 relative overflow-hidden shrink-0 dark:bg-slate-800">
                                    <% if (hackathon.image) { %>
                                        <img src="<%= hackathon.image %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 opacity-90 dark:opacity-80" alt="<%= hackathon.title %> Banner" />
                                    <% } else { %>
                                        <div class="absolute inset-0 bg-gradient-to-tr from-blue-600 to-purple-600">
                                            <div class="absolute inset-0 bg-black/20 mix-blend-overlay group-hover:scale-110 transition-transform duration-700"></div>
                                        </div>
                                    <% } %>
                                    <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md px-3 py-1 rounded-full text-slate-800 text-xs font-bold shadow-sm dark:bg-black/50 dark:text-white dark:border dark:border-white/20">
                                        <%= hackathon.status || 'Active' %>
                                    </div>
                                </div>
                                <div class="p-6 flex-1 flex flex-col">
                                    <h3 class="text-xl font-extrabold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors dark:text-white dark:group-hover:text-blue-400"><%= hackathon.title %></h3>
                                    <p class="text-sm text-slate-600 mb-6 line-clamp-2 leading-relaxed dark:text-slate-400"><%= hackathon.description %></p>
                                    
                                    <div class="mt-auto pt-4 border-t border-gray-100 flex justify-between items-center dark:border-white/10">
                                        <span class="text-sm font-bold text-slate-900 bg-slate-100 px-3 py-1 rounded-lg dark:bg-slate-800 dark:text-white"><%= new Date(hackathon.date).toLocaleDateString() %></span>
                                        <div class="space-x-2 flex items-center">
                                            <button class="text-slate-400 hover:text-blue-600 transition-colors dark:hover:text-blue-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg></button>
                                            <form action="/api/admin/hackathons/<%= hackathon._id %>/delete" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this hackathon?');">
                                                <button type="submit" class="text-slate-400 hover:text-red-600 transition-colors dark:hover:text-red-400" title="Delete Hackathon">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-span-full p-8 text-center text-slate-500 dark:text-slate-400 bg-white rounded-3xl border border-gray-200 dark:bg-white/5 dark:border-white/10">
                            No hackathons found in database.
                        </div>
                    <% } %>
                </div>
            </main>
        </div>
    </div>

    <!-- Create Hackathon Modal -->
    <div id="createModal" class="fixed inset-0 z-50 hidden bg-slate-900/50 backdrop-blur-sm flex justify-center items-center overflow-y-auto">
        <div class="bg-white dark:bg-[#151824] w-full max-w-2xl rounded-2xl shadow-2xl border border-gray-200 dark:border-white/10 my-8 relative overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-white/10 flex justify-between items-center bg-slate-50 dark:bg-transparent">
                <h3 class="text-xl font-extrabold text-slate-900 dark:text-white">Create New Hackathon</h3>
                <button onclick="document.getElementById('createModal').classList.add('hidden')" class="text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/api/admin/hackathons" method="POST" enctype="multipart/form-data" class="p-6 space-y-4">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2 dark:text-slate-400">Hackathon Title</label>
                        <input type="text" name="title" required class="w-full px-4 py-2 bg-slate-50 border border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none dark:bg-[#0e111a] dark:border-white/5 dark:text-white dark:placeholder-slate-600" placeholder="e.g. Global Tech Challenge" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2 dark:text-slate-400">Domain / Category</label>
                        <select name="domain" class="w-full px-4 py-2 bg-slate-50 border border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none dark:bg-[#0e111a] dark:border-white/5 dark:text-white appearance-none">
                            <option value="AI/ML">AI/ML</option>
                            <option value="Blockchain">Blockchain</option>
                            <option value="Sustainability">Sustainability</option>
                            <option value="Healthcare/MedTech">Healthcare/MedTech</option>
                            <option value="Education">Education</option>
                            <option value="Cybersecurity">Cybersecurity</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2 dark:text-slate-400">Description</label>
                    <textarea name="description" required rows="3" class="w-full px-4 py-2 bg-slate-50 border border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none dark:bg-[#0e111a] dark:border-white/5 dark:text-white dark:placeholder-slate-600" placeholder="Describe the hackathon theme and rules..."></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2 dark:text-slate-400">Mode</label>
                        <select name="mode" class="w-full px-4 py-2 bg-slate-50 border border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none dark:bg-[#0e111a] dark:border-white/5 dark:text-white appearance-none">
                            <option value="Online">Online</option>
                            <option value="Offline">Offline</option>
                            <option value="Hybrid">Hybrid</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2 dark:text-slate-400">Team Size</label>
                        <input type="number" name="teamSize" value="4" min="1" max="10" class="w-full px-4 py-2 bg-slate-50 border border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none dark:bg-[#0e111a] dark:border-white/5 dark:text-white" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2 dark:text-slate-400">Deadline</label>
                        <input type="date" name="deadline" class="w-full px-4 py-2 bg-slate-50 border border-gray-200 rounded-xl text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none dark:bg-[#0e111a] dark:border-white/5 dark:text-white" />
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2 dark:text-slate-400">Hackathon Banner Image</label>
                    <div class="border-2 border-dashed border-gray-300 dark:border-white/10 rounded-xl p-6 text-center hover:bg-slate-50 dark:hover:bg-white/5 transition-colors">
                        <input type="file" name="banner" accept="image/*" class="w-full text-sm text-slate-500 dark:text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-500/20 dark:file:text-blue-300 dark:hover:file:bg-blue-500/30" />
                        <p class="text-xs text-slate-400 mt-2">JPEG, PNG, JPG supported. Powered by Cloudinary.</p>
                    </div>
                </div>

                <div class="pt-4 mt-6 border-t border-gray-200 dark:border-white/10 flex justify-end gap-3">
                    <button type="button" onclick="document.getElementById('createModal').classList.add('hidden')" class="px-5 py-2 text-sm font-bold text-slate-600 hover:text-slate-900 bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors dark:text-slate-300 dark:hover:text-white dark:bg-[#252a3d] dark:hover:bg-[#2d334a]">Cancel</button>
                    <button type="submit" class="px-5 py-2 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-xl shadow-md hover:shadow-lg transition-all hover:-translate-y-0.5 shadow-[0_4px_15px_rgba(37,99,235,0.3)]">Launch Hackathon</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
