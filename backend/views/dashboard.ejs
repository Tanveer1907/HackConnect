<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HackConnect Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="antialiased font-sans text-slate-800 overflow-x-hidden transition-colors duration-300 dark:bg-[#0f172a] dark:text-slate-200">
    <div class="flex flex-col flex-1 min-h-screen">
        <div class="flex flex-1 overflow-hidden max-w-[1600px] w-full mx-auto relative">
            <%- include('partials/sidebar') %>

            <main class="flex-1 p-6 md:p-10 overflow-y-auto z-10 bg-slate-50 dark:bg-transparent">
                <div class="mb-10">
                    <h1 class="text-3xl font-extrabold text-slate-900 mb-2 tracking-tight drop-shadow-sm dark:text-white dark:drop-shadow-md">
                        System Overview 👋
                    </h1>
                    <p class="text-slate-600 font-medium dark:text-slate-400">Manage your PostgreSQL database, Users, and Hackathons efficiently.</p>
                </div>

                <!-- Stats Grid mimicking the frontend cards -->
                <div class="grid grid-cols-1 xl:grid-cols-3 gap-6 mb-12">
                    <!-- Main Admin Card -->
                    <div class="xl:col-span-2 bg-white rounded-3xl p-8 border border-gray-200 shadow-sm flex flex-col md:flex-row items-center justify-between gap-8 hover:shadow-md hover:border-blue-300 transition-all duration-300 group dark:bg-white/5 dark:backdrop-blur-md dark:border-white/10 dark:shadow-[0_8px_30px_rgba(0,0,0,0.2)] dark:hover:shadow-[0_0_30px_rgba(59,130,246,0.15)] dark:hover:border-white/20">
                        <div class="flex-1 w-full">
                            <div class="flex justify-between items-center mb-3">
                                <h3 class="font-extrabold text-xl text-slate-900 group-hover:text-blue-600 transition-colors dark:text-white dark:group-hover:text-blue-400">Database Migration Status</h3>
                                <span class="text-blue-600 font-bold text-sm bg-blue-50 px-3 py-1 rounded-full border border-blue-200 shadow-sm dark:text-blue-300 dark:bg-blue-500/20 dark:border-blue-500/30 dark:shadow-[0_0_10px_rgba(59,130,246,0.2)]">Pending</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-2.5 mb-5 overflow-hidden shadow-inner border border-gray-200 dark:bg-slate-800/80 dark:border-white/5">
                                <div class="bg-gradient-to-r from-blue-600 to-indigo-400 h-full rounded-full shadow-sm dark:shadow-[0_0_10px_rgba(59,130,246,0.8)]" style="width: 25%"></div>
                            </div>
                            <p class="text-slate-600 mb-8 leading-relaxed dark:text-slate-300">Run `npx prisma migrate dev` to push your schema to PostgreSQL and complete the setup.</p>
                            <div class="flex flex-wrap gap-4">
                                <button class="px-6 py-2.5 bg-blue-600 text-white font-bold rounded-xl shadow-[0_4px_15px_rgba(59,130,246,0.4)] hover:bg-blue-500 hover:shadow-[0_0_20px_rgba(59,130,246,0.6)] hover:-translate-y-0.5 transition-all">Migrate Now</button>
                            </div>
                        </div>
                        <div class="w-full md:w-56 h-40 rounded-2xl bg-slate-900 overflow-hidden flex-shrink-0 shadow-[0_10px_30px_rgba(0,0,0,0.5)] border border-white/10 relative group-hover:border-blue-500/30 transition-colors">
                            <div class="absolute inset-0 bg-gradient-to-tr from-blue-900/60 to-purple-900/60 flex items-center justify-center">
                                <span class="text-5xl">🐘</span>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Stats -->
                    <div class="bg-white rounded-3xl p-8 border border-gray-200 shadow-sm transition-all duration-300 dark:bg-white/5 dark:backdrop-blur-md dark:border-white/10 dark:shadow-[0_8px_30px_rgba(0,0,0,0.2)] dark:hover:border-white/20">
                        <div class="flex justify-between items-center mb-8">
                            <h3 class="font-extrabold text-xl text-slate-900 dark:text-white">Quick Stats</h3>
                        </div>
                        <div class="space-y-4">
                            <div class="flex flex-col gap-2 bg-slate-50 p-4 rounded-xl border border-gray-100 dark:bg-slate-800/50 dark:border-white/5">
                                <div class="flex justify-between items-center">
                                    <h4 class="font-bold text-slate-900 dark:text-white">Total Users</h4>
                                    <span class="text-[10px] font-bold px-2 py-1 bg-teal-100 text-teal-600 rounded-md uppercase dark:bg-teal-900/30 dark:text-teal-400">DB</span>
                                </div>
                                <p class="text-2xl font-black text-blue-600 mt-1 drop-shadow-sm dark:text-blue-400"><%= totalUsers %></p>
                            </div>
                            <div class="flex flex-col gap-2 bg-slate-50 p-4 rounded-xl border border-gray-100 dark:bg-slate-800/50 dark:border-white/5">
                                <div class="flex justify-between items-center">
                                    <h4 class="font-bold text-slate-900 dark:text-white">Active Hackathons</h4>
                                    <span class="text-[10px] font-bold px-2 py-1 bg-purple-100 text-purple-600 rounded-md uppercase dark:bg-purple-900/30 dark:text-purple-400">Live</span>
                                </div>
                                <p class="text-2xl font-black text-purple-600 mt-1 drop-shadow-sm dark:text-purple-400"><%= activeHackathons %></p>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
</body>
</html>
